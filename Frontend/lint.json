Promise<{ actions_history: any[]; blocked_ips: string[]; locked_users: string[] }> {\n  const response = await fetch(`${BASE_URL}/actions`);\n  if (!response.ok) throw new Error('Failed to fetch actions');\n  return response.json();\n}\n\nexport async function fetchTimeline(): Promise<any[]> {\n  const response = await fetch(`${BASE_URL}/timeline`);\n  if (!response.ok) throw new Error('Failed to fetch timeline');\n  return response.json();\n}\n\nexport async function triggerAttack(): Promise<{ status: string }> {\n  const response = await fetch(`${BASE_URL}/simulate_attack`, {\n    method: 'POST',\n  });\n  if (!response.ok) throw new Error('Failed to trigger attack');\n  return response.json();\n}\n\nexport async function resetSystem(): Promise<{ status: string }> {\n  const response = await fetch(`${BASE_URL}/reset`, {\n    method: 'POST',\n  });\n  if (!response.ok) throw new Error('Failed to reset system');\n  return response.json();\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Ansh\\Work\\Projects\\1-2\\Athena\\Frontend\\src\\components\\AIAnalysisPanel.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Ansh\\Work\\Projects\\1-2\\Athena\\Frontend\\src\\components\\FloatingControlPanel.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Ansh\\Work\\Projects\\1-2\\Athena\\Frontend\\src\\components\\LiveActivityFeed.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Ansh\\Work\\Projects\\1-2\\Athena\\Frontend\\src\\components\\ResponseEngine.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarn